NODE_ENV=development
PORT=5000

# ─── Database (Neon) ──────────────────────────────────────────────────────────
# Get both from neon.tech → your project → Connection Details
# Switch the dropdown between "Connection pooling" and "Direct connection"
DATABASE_URL="postgresql://user:password@ep-xxxx.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxxx.neon.tech/neondb?sslmode=require"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Make up any long random strings — e.g. run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string_at_least_64_chars
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string_64_chars

# ─── Redis (Upstash) ──────────────────────────────────────────────────────────
# Optional — app works without this (uses in-memory fallback in dev)
# Get from upstash.com → your Redis database → Connect → .env
REDIS_URL=redis://default:your_password@your-host.upstash.io:6379

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Get from cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your_api_secret_here

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get from dashboard.stripe.com → Developers → API Keys
# Use sk_test_... for development, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# Get from Stripe Dashboard → Webhooks → your endpoint → Signing secret
# Leave as placeholder if not using webhooks locally
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# ─── Resend (email) ───────────────────────────────────────────────────────────
# Optional — emails print to console in dev if not set
# Get from resend.com → API Keys
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@yourdomain.com

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Optional — only needed if you want Google login
# Get from console.cloud.google.com → Credentials → OAuth 2.0 Client
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── App URLs ─────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
API_URL=http://localhost:5000
